PDF_DATED_DIR=~/Documents

# tools/ssh_kb_ru: loads repo-root .env. SSH_USE_STORED_CREDENTIALS=1 skips keychain prompts.
# SSH_USE_STORED_CREDENTIALS=1

# Server profile: cmw | cmwlab
SERVER_PROFILE=cmw

# --- Profile "cmw" ---
CMW_SSH_HOST=ssh-host.example
CMW_SSH_PORT=22
CMW_SSH_USERNAME=ssh-username
# Optional if using keychain + SSH_USE_STORED_CREDENTIALS=1
CMW_SSH_PASSWORD=ssh-password

CMW_SQL_HOSTNAME=localhost
CMW_SQL_IP=127.0.0.1
CMW_SQL_PORT=3306
CMW_SQL_PORT_LOCAL=3307
CMW_SQL_USERNAME=db-username
# Optional if using keychain + SSH_USE_STORED_CREDENTIALS=1
CMW_SQL_PASSWORD=db-password
CMW_SQL_DATABASE=db-name

# PHPKB local repo path for image/bundle git sync (phpkb_copy_images.py, phpkb_ingest.py)
CMW_KB_REPO_PATH=/var/www/html

# Remote PHPKB repo path on production server for git pull (utilities/ssh_pull.py)
CMW_SSH_KB_REPO_PATH=/var/www/html

# --- Profile "cmwlab" ---
CMWLAB_SSH_HOST=ssh-host.example
CMWLAB_SSH_PORT=22
CMWLAB_SSH_USERNAME=ssh-username
CMWLAB_SSH_PASSWORD=ssh-password

CMWLAB_SQL_HOSTNAME=localhost
CMWLAB_SQL_IP=127.0.0.1
CMWLAB_SQL_PORT=3306
CMWLAB_SQL_PORT_LOCAL=3307
CMWLAB_SQL_USERNAME=db-username
CMWLAB_SQL_PASSWORD=db-password
CMWLAB_SQL_DATABASE=db-name

CMWLAB_KB_REPO_PATH=/var/www/html
CMWLAB_SSH_KB_REPO_PATH=/var/www/html

# Product source code repo (for validating KB article claims against implementation)
# PLATFORM_SOURCE_CODE=D:\Repo\CBAP_MONO
